{{#if_eq user.type 'faculty'}}
<h4 class="blue-text text-darken-4">Faculty Profile & History</h4>
<hr>

<div class="row">
    {{#each faculty_profile}}
    <div class="col s12 m12">
        <div class="card white" style="border-top: 5px solid #003366;">
            <div class="card-content">
                <span class="card-title" style="color: #003366; font-weight: bold;">Personal Details</span>
                <table class="striped">
                    <tbody>
                        <tr>
                            <td><b>Name:</b></td>
                            <td>{{faculty_name}}</td>
                        </tr>
                        <tr>
                            <td><b>Designation:</b></td>
                            <td>{{designation}}</td>
                        </tr>
                        <tr>
                            <td><b>Department:</b></td>
                            <td>{{department}}</td>
                        </tr>
                        <tr>
                            <td><b>Qualification:</b></td>
                            <td>{{qualification}}</td>
                        </tr>
                        <tr>
                            <td><b>Teaching Experience:</b></td>
                            <td>{{teaching_exp}} Years</td>
                        </tr>
                        <tr>
                            <td><b>Nature of Appointment:</b></td>
                            <td>{{appointment}}</td>
                        </tr>
                        <tr>
                            <td><b>Date of Joining:</b></td>
                            <td>{{date_of_join}}</td>
                        </tr>
                        <tr>
                            <td><b>Date of Birth:</b></td>
                            <td>{{DOB}}</td>
                        </tr>
                        <tr>
                            <td><b>Salary:</b></td>
                            <td>{{salary}}</td>
                        </tr>
                    </tbody>
                </table>
            </div>
            <div class="card-action" style="background-color: #f5f5f5;">
                <a href="/profile/faculty/edit/{{id}}" class="blue-text text-darken-4" style="font-weight: bold;">Edit Profile Info</a>
            </div>
        </div>
    </div>
    {{else}}
    <div class="col s12 center-align" style="margin-top: 20px;">
        <div class="card-panel">
            <p class="flow-text">Personal profile information has not been added yet.</p>
            <a href="/profile/faculty/addProfile" class="waves-effect waves-light btn-large" style="background-color: #003366;">Create Profile</a>
        </div>
    </div>
    {{/each}}
</div>

<div class="row">
    <div class="col s12">
        <div class="card white" style="border-top: 5px solid #003366;">
            <div class="card-content">
                <span class="card-title" style="color: #003366; font-weight: bold;">
                    <i class="fa fa-history"></i> Year-wise Appraisal History
                </span>
                <p class="grey-text">Access your historical appraisal data for previous academic years.</p>
                
                <table class="highlight responsive-table" style="margin-top: 20px;">
                    <thead>
                        <tr style="color: #003366;">
                            <th>Academic Year</th>
                            <th>Current Status</th>
                            <th class="center-align">Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        {{#if history}}
                            {{#each history}}
                            <tr>
                                <td><b>{{academic_year}}</b></td>
                                <td><span class="badge blue white-text" style="border-radius: 4px; float: none;">Record Exists</span></td>
                                <td class="center-align">
                                    <a href="/users/faculty/facultyOverview" class="btn-small" style="background-color: #003366;">
                                        Open Dashboard
                                    </a>
                                </td>
                            </tr>
                            {{/each}}
                        {{else}}
                            <tr>
                                <td colspan="3" class="center-align grey-text">No previous appraisal records found.</td>
                            </tr>
                        {{/if}}
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

{{else}}
<div class="container center-align">
    <h5 class="red-text">Not Authorized</h5>
    <p>Please log in as a Faculty member to view this page.</p>
    <a href="/" class="btn" style="background-color: #003366;">Back to Home</a>
</div>
{{/if_eq}}