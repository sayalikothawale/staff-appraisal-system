<div class="container" style="margin-top: 30px; margin-bottom: 50px;">
    
    <div class="card-panel white" style="border: 2px solid #1a237e; border-radius: 10px; padding: 40px;">
        
        <!-- ================= HEADER ================= -->
        <div class="center-align">
            <h4 style="color: #1a237e; font-weight: bold;">
                Walchand Institute of Technology, Solapur
            </h4>
            <h5 style="color: #1a237e;">
                PBAS Self-Assessment Summary Report
            </h5>
            <h6 class="grey-text">
                Academic Year: <b>{{year}}</b>
            </h6>
        </div>

        <div class="divider" style="margin: 20px 0;"></div>

        <!-- ================= SUMMARY TABLE ================= -->
        <table class="striped bordered highlight centered" style="margin-top: 20px;">
            <thead>
                <tr style="background-color: #1a237e; color: white;">
                    <th>Assessment Category</th>
                    <th>Max Score</th>
                    <th>Earned Score</th>
                </tr>
            </thead>

            <tbody>

                <tr>
                    <td>Part I: Teaching-Learning & Evaluation</td>
                    <td>25</td>
                    <td><b>{{totalP1}}</b></td>
                </tr>

                <tr>
                    <td>Part II: Research & Publications</td>
                    <td>-</td>
                    <td><b>{{totalP2}}</b></td>
                </tr>

                <tr>
                    <td>Part III: Innovation & Extension</td>
                    <td>-</td>
                    <td><b>{{totalP3}}</b></td>
                </tr>

                <tr>
                    <td>Part IV: Administrative Duties</td>
                    <td>-</td>
                    <td><b>{{totalP4}}</b></td>
                </tr>

                <tr style="background-color: #e8eaf6; font-size: 1.2rem;">
                    <td><b style="color: #1a237e;">TOTAL API SCORE</b></td>
                    <td>-</td>
                    <td><b style="color:#1a237e;">{{grandTotal}}</b></td>
                </tr>

            </tbody>
        </table>

        <!-- ================= ENCLOSURE ================= -->
        <div style="margin-top: 40px;">
            <h6><b>Enclosure:</b></h6>
            <p class="grey-text">
                e.g. Supporting documents for publications / certificates / course files
            </p>

            <input type="text" placeholder="Enter enclosure details" class="browser-default" style="padding:8px;">
        </div>

        <!-- ================= DECLARATION ================= -->
        <div style="margin-top: 30px;">
            <label>
                <input type="checkbox" required />
                <span>
                    I hereby declare that the information provided is true and correct to the best of my knowledge.
                </span>
            </label>
        </div>

        <!-- ================= SIGNATURE ================= -->
        <div class="row" style="margin-top: 60px;">
            
            <div class="col s6 center-align">
                <p>________________________</p>
                <b>Faculty Signature</b>
            </div>

            <div class="col s6 center-align">
                <p>________________________</p>
                <b>Principal</b><br>
                <span class="grey-text">Institute Seal</span>
            </div>

        </div>

        <!-- ================= BUTTONS ================= -->
        <div class="row no-print" style="margin-top: 50px;">
            
            <div class="col s12 center-align">

                <!-- EXPORT -->
                <button onclick="window.print()" 
                    class="btn-large indigo darken-4">
                    <i class="material-icons left">picture_as_pdf</i>
                    Export PDF
                </button>

                <br><br>

                <!-- BACK TO DASHBOARD -->
                <a href="/users/faculty/facultyOverview" 
                   class="btn-large green darken-2">
                    Save & Go to Dashboard →
                </a>

            </div>

        </div>

    </div>
</div>

<!-- ================= PRINT STYLE ================= -->
<style>
@media print {
    .no-print, .btn-large, input, label {
        display: none !important;
    }

    body {
        background: white !important;
    }

    .card-panel {
        border: none !important;
        box-shadow: none !important;
    }
}
</style>