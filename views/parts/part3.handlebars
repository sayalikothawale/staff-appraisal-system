<div class="container" style="margin-top: 30px; margin-bottom: 50px;">
    <div class="card white" style="border-top: 5px solid #6a1b9a; border-radius: 8px;">
        <div class="card-content">
            <h4 class="center-align" style="color: #6a1b9a; font-weight: bold;">Part - III: Innovation & Extension</h4>
            <p class="center-align grey-text">Academic Year: <b style="color: #6a1b9a;">{{academicYear}}</b></p>
            <br>

            <form action="/part3/save" method="POST">
                <input type="hidden" name="academicYear" value="{{academicYear}}">

                <table class="highlight centered bordered responsive-table">
                    <thead>
                        <tr style="background-color: #f3e5f5; color: #6a1b9a;">
                            <th style="width: 25%;">Activity Name</th>
                            <th style="width: 25%;">Organization/Client</th>
                            <th style="width: 15%;">Duration</th>
                            <th style="width: 10%;">Points</th>
                            <th style="width: 15%;">Enclosure</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody id="table-body">
                        {{#if savedInnovation.length}}
                            {{#each savedInnovation}}
                            <tr class="innovation-row">
                                <td><input type="text" name="activity" value="{{this.activity}}" required></td>
                                <td><input type="text" name="organization" value="{{this.organization}}"></td>
                                <td><input type="text" name="duration" value="{{this.duration}}"></td>
                                <td><input type="number" name="points" value="{{this.points}}"></td>
                                <td><input type="text" name="enclosure" value="{{this.enclosure}}"></td>
                                <td><a href="javascript:void(0)" class="remove-row red-text"><i class="material-icons">delete</i></a></td>
                            </tr>
                            {{/each}}
                        {{else}}
                            <tr class="innovation-row">
                                <td><input type="text" name="activity" placeholder="e.g. Patent Filing" required></td>
                                <td><input type="text" name="organization" placeholder="e.g. WIT Solapur / Industry"></td>
                                <td><input type="text" name="duration" placeholder="e.g. 6 Months"></td>
                                <td><input type="number" name="points" value="0"></td>
                                <td><input type="text" name="enclosure" placeholder="e.g. 3"></td>
                                <td><a href="javascript:void(0)" class="remove-row red-text"><i class="material-icons">delete</i></a></td>
                            </tr>
                        {{/if}}
                    </tbody>
                </table>

                <div class="row" style="margin-top: 20px;">
                    <div class="col s12 center-align">
                        <button type="button" id="add-row" class="btn-flat purple-text text-darken-2" style="font-weight: bold;">
                            <i class="material-icons left">add_circle</i> ADD ACTIVITY
                        </button>
                    </div>
                </div>

                <div class="center-align" style="margin-top: 30px;">
                    <button type="submit" class="btn-large purple darken-2" style="width: 100%; max-width: 300px;">
                        SAVE PART III
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<script>
    document.addEventListener('DOMContentLoaded', function() {
        const tableBody = document.getElementById('table-body');
        const addRowBtn = document.getElementById('add-row');

        addRowBtn.addEventListener('click', function() {
            const newRow = document.createElement('tr');
            newRow.className = 'innovation-row';
            newRow.innerHTML = `
                <td><input type="text" name="activity" placeholder="Activity Name" required></td>
                <td><input type="text" name="organization" placeholder="Organization"></td>
                <td><input type="text" name="duration" placeholder="Duration"></td>
                <td><input type="number" name="points" value="0"></td>
                <td><input type="text" name="enclosure" placeholder="Encl. No."></td>
                <td><a href="javascript:void(0)" class="remove-row red-text"><i class="material-icons">delete</i></a></td>
            `;
            tableBody.appendChild(newRow);
        });

        tableBody.addEventListener('click', function(e) {
            if (e.target.closest('.remove-row')) { e.target.closest('tr').remove(); }
        });
    });
</script>