<script>
function updateSerial(id){
let rows=document.querySelectorAll(`#${id} tr`);
let count=1;
rows.forEach(r=>{
if(r.style.color!=="gray"){
r.cells[0].innerText=count++;
}
});
}

function addRow(id){
let row=`<tr>${document.querySelector(`#${id} tr:nth-child(2)`).innerHTML}</tr>`;
document.getElementById(id).insertAdjacentHTML('beforeend',row);
updateSerial(id);
}

document.addEventListener('click',function(e){
if(e.target.classList.contains('remove')){
e.target.closest('tr').remove();
['A','B','C','D','E','F','G1','G2'].forEach(updateSerial);
}
});

['A','B','C','D','E','F','G1','G2'].forEach(updateSerial);
</script>