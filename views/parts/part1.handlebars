<div class="container" style="margin-top: 30px; margin-bottom: 50px;">
    <div class="card white" style="border-top: 5px solid #003366; border-radius: 8px;">
        <div class="card-content">
            <h4 class="center-align" style="color: #003366; font-weight: bold;">Part - I: Teaching Process</h4>
            <p class="center-align grey-text">Academic Year: <b style="color: #003366;">{{academicYear}}</b> | Max Credit Points: 25</p>
            <br>

            <form action="/part1/save" method="POST">
                {{!-- CRITICAL: Hidden field to ensure data is saved to the correct year --}}
                <input type="hidden" name="academicYear" value="{{academicYear}}">

                <table class="highlight centered bordered responsive-table" id="teaching-table">
                    <thead>
                        <tr style="background-color: #f5f5f5; color: #003366;">
                            <th style="width: 12%;">Semester</th>
                            <th style="width: 25%;">Course Name</th>
                            <th style="width: 8%;">Type</th>
                            <th style="width: 10%;">Scheduled</th>
                            <th style="width: 10%;">Held</th>
                            <th style="width: 10%;">Points</th>
                            <th style="width: 15%;">Enclosure</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody id="table-body">
                        {{#if savedCourses}}
                            {{#each savedCourses}}
                            <tr class="teaching-row">
                                <td>
                                    <select name="semester" class="browser-default" style="border:none; border-bottom: 1px solid #9e9e9e;">
                                        <option value="Sem-I" {{#if_eq this.semester 'Sem-I'}}selected{{/if_eq}}>Sem-I</option>
                                        <option value="Sem-II" {{#if_eq this.semester 'Sem-II'}}selected{{/if_eq}}>Sem-II</option>
                                    </select>
                                </td>
                                <td><input type="text" name="course" value="{{this.courseName}}" placeholder="Course Name" required></td>
                                <td><input type="text" name="type" value="{{this.type}}" placeholder="L/T/P"></td>
                                <td><input type="number" name="scheduled" class="calc-trigger" value="{{this.scheduled}}"></td>
                                <td><input type="number" name="held" class="calc-trigger" value="{{this.actuallyHeld}}"></td>
                                <td><input type="text" name="points" class="points-field" value="{{this.points}}" readonly style="border:none; font-weight:bold; color:#003366;"></td>
                                <td><input type="text" name="enclosure" value="{{this.enclosure}}" placeholder="e.g. 1"></td>
                                <td><a href="javascript:void(0)" class="remove-row red-text"><i class="material-icons">delete</i></a></td>
                            </tr>
                            {{/each}}
                        {{else}}
                            {{!-- Default Blank Row if no data exists --}}
                            <tr class="teaching-row">
                                <td>
                                    <select name="semester" class="browser-default" style="border:none; border-bottom: 1px solid #9e9e9e;">
                                        <option value="Sem-I">Sem-I</option>
                                        <option value="Sem-II">Sem-II</option>
                                    </select>
                                </td>
                                <td><input type="text" name="course" placeholder="e.g. System Programming" required></td>
                                <td><input type="text" name="type" placeholder="L/T/P" maxlength="1"></td>
                                <td><input type="number" name="scheduled" class="calc-trigger" value="0"></td>
                                <td><input type="number" name="held" class="calc-trigger" value="0"></td>
                                <td><input type="text" name="points" class="points-field" readonly style="border:none; font-weight:bold; color:#003366;" value="0.00"></td>
                                <td><input type="text" name="enclosure" placeholder="e.g. 1"></td>
                                <td><a href="javascript:void(0)" class="remove-row red-text"><i class="material-icons">delete</i></a></td>
                            </tr>
                        {{/if}}
                    </tbody>
                </table>

                <div class="row" style="margin-top: 20px;">
                    <div class="col s12 center-align">
                        <button type="button" id="add-row" class="btn-flat blue-text text-darken-4" style="font-weight: bold;">
                            <i class="material-icons left">add_circle</i> ADD ANOTHER COURSE
                        </button>
                    </div>
                </div>

                <div class="center-align" style="margin-top: 30px;">
                    <button type="submit" class="btn-large" style="background-color: #003366; width: 100%; max-width: 300px;">
                        SAVE TEACHING PROCESS
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<script>
    document.addEventListener('DOMContentLoaded', function() {
        const tableBody = document.getElementById('table-body');
        const addRowBtn = document.getElementById('add-row');

        function calculateRow(row) {
            const scheduledInput = row.querySelector('input[name="scheduled"]');
            const heldInput = row.querySelector('input[name="held"]');
            const pointsField = row.querySelector('.points-field');

            if (!scheduledInput || !heldInput || !pointsField) return;

            const scheduled = parseFloat(scheduledInput.value) || 0;
            const held = parseFloat(heldInput.value) || 0;

            if (scheduled > 0) {
                pointsField.value = ((held / scheduled) * 10).toFixed(2);
            } else {
                pointsField.value = "0.00";
            }
        }

        addRowBtn.addEventListener('click', function() {
            const newRow = document.createElement('tr');
            newRow.className = 'teaching-row';
            newRow.innerHTML = `
                <td>
                    <select name="semester" class="browser-default" style="border:none; border-bottom: 1px solid #9e9e9e;">
                        <option value="Sem-I">Sem-I</option>
                        <option value="Sem-II">Sem-II</option>
                    </select>
                </td>
                <td><input type="text" name="course" placeholder="Course Name" required></td>
                <td><input type="text" name="type" placeholder="L/T/P"></td>
                <td><input type="number" name="scheduled" class="calc-trigger" value="0"></td>
                <td><input type="number" name="held" class="calc-trigger" value="0"></td>
                <td><input type="text" name="points" class="points-field" readonly style="border:none; font-weight:bold; color:#003366;" value="0.00"></td>
                <td><input type="text" name="enclosure" placeholder="e.g. 1"></td>
                <td><a href="javascript:void(0)" class="remove-row red-text"><i class="material-icons">delete</i></a></td>
            `;
            tableBody.appendChild(newRow);
        });

        tableBody.addEventListener('input', function(e) {
            if (e.target.classList.contains('calc-trigger')) {
                calculateRow(e.target.closest('tr'));
            }
        });

        tableBody.addEventListener('click', function(e) {
            if (e.target.closest('.remove-row')) {
                e.target.closest('tr').remove();
            }
        });

        // Run calculation once for any saved data shown on load
        document.querySelectorAll('.teaching-row').forEach(row => {
            calculateRow(row);
        });
    });
</script>