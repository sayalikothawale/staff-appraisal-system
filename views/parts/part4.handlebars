<div class="container" style="margin-top: 30px; margin-bottom: 50px;">
    <div class="card white" style="border-top: 5px solid #ff8f00; border-radius: 8px;">
        <div class="card-content">
            <h4 class="center-align" style="color: #ff8f00; font-weight: bold;">Part - IV: Administrative & Professional Development</h4>
            <p class="center-align grey-text">Academic Year: <b style="color: #ff8f00;">{{academicYear}}</b></p>
            <br>

            <form action="/part4/save" method="POST">
                <input type="hidden" name="academicYear" value="{{academicYear}}">

                <table class="highlight centered bordered responsive-table">
                    <thead>
                        <tr style="background-color: #fff8e1; color: #ff8f00;">
                            <th style="width: 35%;">Role / Responsibility</th>
                            <th style="width: 25%;">Level (Dept/Inst/Univ)</th>
                            <th style="width: 15%;">Points</th>
                            <th style="width: 15%;">Encl. No.</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody id="table-body">
                        {{#if savedAdmin.length}}
                            {{#each savedAdmin}}
                            <tr class="admin-row">
                                <td><input type="text" name="role" value="{{this.role}}" required></td>
                                <td><input type="text" name="level" value="{{this.level}}"></td>
                                <td><input type="number" name="points" value="{{this.points}}"></td>
                                <td><input type="text" name="enclosure" value="{{this.enclosure}}"></td>
                                <td><a href="javascript:void(0)" class="remove-row red-text"><i class="material-icons">delete</i></a></td>
                            </tr>
                            {{/each}}
                        {{else}}
                            <tr class="admin-row">
                                <td><input type="text" name="role" placeholder="e.g. T&P Coordinator" required></td>
                                <td><input type="text" name="level" placeholder="e.g. Institute Level"></td>
                                <td><input type="number" name="points" value="0"></td>
                                <td><input type="text" name="enclosure" placeholder="e.g. 4"></td>
                                <td><a href="javascript:void(0)" class="remove-row red-text"><i class="material-icons">delete</i></a></td>
                            </tr>
                        {{/if}}
                    </tbody>
                </table>

                <div class="row" style="margin-top: 20px;">
                    <div class="col s12 center-align">
                        <button type="button" id="add-row" class="btn-flat amber-text text-darken-4" style="font-weight: bold;">
                            <i class="material-icons left">add_circle</i> ADD RESPONSIBILITY
                        </button>
                    </div>
                </div>

                <div class="center-align" style="margin-top: 30px;">
                    <button type="submit" class="btn-large amber darken-3" style="width: 100%; max-width: 300px;">
                        SAVE PART IV
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<script>
    document.addEventListener('DOMContentLoaded', function() {
        const tableBody = document.getElementById('table-body');
        const addRowBtn = document.getElementById('add-row');

        addRowBtn.addEventListener('click', function() {
            const newRow = document.createElement('tr');
            newRow.className = 'admin-row';
            newRow.innerHTML = `
                <td><input type="text" name="role" placeholder="Role Name" required></td>
                <td><input type="text" name="level" placeholder="Level"></td>
                <td><input type="number" name="points" value="0"></td>
                <td><input type="text" name="enclosure" placeholder="Encl. No."></td>
                <td><a href="javascript:void(0)" class="remove-row red-text"><i class="material-icons">delete</i></a></td>
            `;
            tableBody.appendChild(newRow);
        });

        tableBody.addEventListener('click', function(e) {
            if (e.target.closest('.remove-row')) { e.target.closest('tr').remove(); }
        });
    });
</script>