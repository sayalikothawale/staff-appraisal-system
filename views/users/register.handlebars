<div class="container" style="margin-top: 50px; margin-bottom: 50px;">
    <div class="row">
        <div class="col s12 m8 offset-m2 l6 offset-l3">
            <div class="card white" style="border-radius: 10px; box-shadow: 0 10px 25px rgba(0,0,0,0.1);">
                <div class="card-content">
                    <div class="center-align">
                        <h4 style="color: #003366; font-weight: bold;">Registration</h4>
                        <p class="grey-text">Join the WIT PBAS Portal</p>
                    </div>

                    <form action="/users/register" method="POST">
                        <div class="center-align" style="margin: 20px 0;">
                            <label style="margin-right: 20px;">
                                <input name="type" type="radio" value="faculty" checked />
                                <span>Faculty</span>
                            </label>
                            <label>
                                <input name="type" type="radio" value="hod" />
                                <span>HOD</span>
                            </label>
                        </div>

                        <div class="input-field">
                            <i class="material-icons prefix">person</i>
                            <input type="text" name="name" id="name" required>
                            <label for="name">Full Name</label>
                        </div>

                        <div class="input-field">
                            <i class="material-icons prefix">email</i>
                            <input type="email" name="email" id="email" required>
                            <label for="email">College Email ID</label>
                        </div>

                        <div class="row" style="margin-bottom: 20px; margin-left: 3rem;">
                            <label style="color: #003366; font-weight: bold; font-size: 0.8rem;">Department</label>
                            <select name="department" id="reg_dept" class="browser-default" 
                                    style="display: block !important; width: 100%; height: 45px; border: none; border-bottom: 1px solid #9e9e9e; background-color: transparent; cursor: pointer; font-size: 1rem; color: #333;" 
                                    required>
                                <option value="" disabled selected>Choose Department</option>
                                <option value="CSE">CSE</option>
                                <option value="IT">IT</option>
                                <option value="E&TC">E&TC</option>
                                <option value="ECE">ECE</option>
                                <option value="ME">ME</option>
                                <option value="CE">CE</option>
                            </select>
                        </div>

                        <div class="input-field">
                            <i class="material-icons prefix">lock</i>
                            <input type="password" name="password" id="password" required>
                            <label for="password">Password</label>
                        </div>

                        <div class="input-field">
                            <i class="material-icons prefix">check_circle</i>
                            <input type="password" name="confirm_password" id="confirm_password" required>
                            <label for="confirm_password">Confirm Password</label>
                        </div>

                        <div class="center-align" style="margin-top: 30px;">
                            <button type="submit" class="btn-large" style="width: 100%; background-color: #003366 !important;">
                                REGISTER ACCOUNT
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    $(document).ready(function() {
        // Force Materialize to refresh any other text fields
        M.updateTextFields();
        
        // This confirms in your browser console (F12) when you change the option
        $('#reg_dept').change(function() {
            console.log("Department selected: " + $(this).val());
        });
    });
</script>

<style>
    /* Styling for the dropdown list items */
    .dropdown-content li > a { color: #003366 !important; }
    /* Fixes the dropdown positioning */
    .dropdown-content { z-index: 9999 !important; }
</style>