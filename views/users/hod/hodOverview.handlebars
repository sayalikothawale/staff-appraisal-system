<div class="container" style="margin-top: 30px;">
    <h4 class="indigo-text text-darken-4">HOD Dashboard</h4>
    <p>Welcome, <b>{{user.name}}</b> (HOD - {{user.department}})</p>

    <div class="row">
        <div class="col s12 m6">
            <div class="card blue-grey darken-1 white-text">
                <div class="card-content">
                    <span class="card-title">My Personal Appraisal</span>
                    <p>Complete your own self-assessment for {{year}}.</p>
                    <p>Status: <b>{{status}}</b></p>
                </div>
                <div class="card-action">
                    <a href="/users/faculty/facultyOverview" class="amber-text">OPEN MY APPRAISAL</a>
                </div>
            </div>
        </div>

        <div class="col s12 m6">
            <div class="card indigo darken-4 white-text">
                <div class="card-content">
                    <span class="card-title">Review Faculty</span>
                    <p>Review and approve appraisals submitted by your department faculty.</p>
                    {{#if pendingCount}}
                        <span class="new badge red" data-badge-caption="Pending">{{pendingCount}}</span>
                    {{/if}}
                </div>
                <div class="card-action">
                    <a href="/users/hod/appraisalList" class="white-text">VIEW FACULTY LIST</a>
                </div>
            </div>
        </div>
    </div>
</div>