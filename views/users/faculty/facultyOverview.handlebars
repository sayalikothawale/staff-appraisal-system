<div class="container" style="margin-top: 30px;">
    <h4 class="blue-text text-darken-4" style="font-weight: bold;">Appraisal Dashboard: {{year}}</h4>
    <p>Current Status: <span class="badge {{#if_eq status 'Draft'}}blue{{else}}orange{{/if_eq}} white-text" style="float: none; font-size: 1rem; border-radius: 4px;">{{status}}</span></p>

    <div class="row" style="margin-top: 40px;">
        <div class="col s12 m6">
            <div class="card hoverable" style="border-radius: 8px;">
                <div class="card-content">
                    <span class="card-title" style="color: #003366; font-weight: bold;">Part 1: Teaching-Learning</span>
                    <p class="grey-text text-darken-2" style="margin-bottom: 15px;">Enter course details, scheduled classes, and student feedback calculation.</p>
                    
                    {{#if p1Done}}
                        <span class="green-text" style="font-weight: bold; display: flex; align-items: center;">
                            <i class="material-icons" style="margin-right: 8px;">check_circle</i> Completed
                        </span>
                    {{else}}
                        <span class="red-text" style="font-weight: bold; display: flex; align-items: center;">
                            <i class="material-icons" style="margin-right: 8px;">info_outline</i> Pending
                        </span>
                    {{/if}}
                </div>
                <div class="card-action">
                    <a href="/part1/view/{{year}}" class="blue-text" style="font-weight: bold;">MANAGE DATA</a>
                </div>
            </div>
        </div>

        <div class="col s12 m6">
            <div class="card hoverable" style="border-radius: 8px;">
                <div class="card-content">
                    <span class="card-title" style="color: #003366; font-weight: bold;">Part 2: Research & Pubs</span>
                    <p class="grey-text text-darken-2" style="margin-bottom: 15px;">Record research papers, journals, conference presentations, and books.</p>
                    
                    {{#if p2Done}}
                        <span class="green-text" style="font-weight: bold; display: flex; align-items: center;">
                            <i class="material-icons" style="margin-right: 8px;">check_circle</i> Completed
                        </span>
                    {{else}}
                        <span class="red-text" style="font-weight: bold; display: flex; align-items: center;">
                            <i class="material-icons" style="margin-right: 8px;">info_outline</i> Pending
                        </span>
                    {{/if}}
                </div>
                <div class="card-action">
                    <a href="/part2/view/{{year}}" class="blue-text" style="font-weight: bold;">MANAGE DATA</a>
                </div>
            </div>
        </div>
    </div>

    <div class="card-panel center-align" style="margin-top: 50px; background-color: #f9f9f9; border: 1px dashed #ccc;">
        {{#if canSubmit}}
            {{#if_eq status 'Draft'}}
                <form action="/summary/submitToHod" method="POST">
                    <h5 class="green-text text-darken-2">Ready for Submission!</h5>
                    <p class="grey-text">All required sections are complete. You can now submit your appraisal for HOD review.</p>
                    <button type="submit" class="btn-large green darken-2" style="width: 100%; max-width: 400px; margin-top: 15px;">
                        <i class="material-icons left">send</i> SUBMIT TO HOD
                    </button>
                </form>
            {{else}}
                <h5 class="orange-text text-darken-3">Submission Locked</h5>
                <p>Appraisal is currently <b>{{status}}</b>. You cannot edit data while under review.</p>
            {{/if_eq}}
        {{else}}
            <h5 class="red-text">Submission Not Enabled</h5>
            <p>Please complete Part 1 and Part 2 (and 3-4) to enable the submission button.</p>
            <button class="btn-large disabled" style="width: 100%; max-width: 400px; margin-top: 15px;">
                SUBMIT TO HOD
            </button>
        {{/if}}
    </div>
</div>