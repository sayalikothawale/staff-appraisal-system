{{#if_eq user.type 'faculty'}}
<h5 class="blue-text text-darken-4">Welcome {{user.name}} to WIT PBAS Portal</h5><br>
<div class="row">
  <div class="col s12 m12">
    <div class="card white" style="border-top: 5px solid #003366;">
      <div class="card-content black-text">
        <span class="card-title" style="font-weight: bold; color: #003366;">Walchand Institute of Technology, Solapur</span>
        
        {{#if result}}
          {{#each result}}
          <div class="row center"><br>
            <p>This portal is for performing the Annual Self-Assessment for the Academic Year <b>{{academic_year}}</b>.</p>
            <form action="#">
                <p><b>Current Active Appraisal</b></p>
                <div class="input-field inline">
                  <input type="text" value="{{academic_year}}" disabled style="text-align: center; width: 150px; color: #003366; font-weight: bold;">
                </div>
                <div class="center-align" style="margin-top: 20px;">
                  <a href="/users/faculty/facultyOverview" class="btn waves-effect waves-light" style="background-color: #003366;">
                    <i class="fa fa-dashboard left"></i> Go to Dashboard
                  </a>
                </div>
            </form>
          </div>
          {{/each}}
        {{else}}
            <div class="row center"><br>
              <p>Welcome! Please initialize your appraisal record for the new academic session.</p>
              <form method="post" action="/" class="col s12">
                  <p><b>Initialize Appraisal for the Current Year</b></p>
                  <div class="input-field inline">
                    <input type="text" name="academic_year" value="{{defaultYear}}" readonly required style="text-align: center; width: 150px; font-weight: bold; color: #003366; border-bottom: 2px solid #003366;">
                    <label class="active" for="academic_year">Academic Year</label>
                  </div>
                  <div style="margin-top: 20px;">
                    <button class="btn waves-effect waves-light" style="background-color: #003366;" type="submit">
                      Proceed to 2025-26 Appraisal
                    </button>
                  </div>
              </form>
              <p class="grey-text" style="margin-top: 20px;">
                <i class="fa fa-info-circle"></i> To view older appraisals (e.g., 2024-25), please visit your <b>Profile</b>.
              </p>
            </div>
        {{/if}}
      </div>
    </div>
  </div>
</div>
{{/if_eq}}

{{#if_eq user.type 'hod'}}
<h5 class="blue-text text-darken-4">Welcome to WIT PBAS Portal</h5><br>
<div class="row">
  <div class="col s12 m12">
    <div class="card white darken-4" style="border-top: 5px solid #003366;">
      <div class="card-content black-text">
        <span class="card-title" style="font-weight: bold; color: #003366;">HOD Dashboard - WIT Solapur</span>
        <p>Review and verify the 360 Degree Feedback and research contributions for your department faculty members.</p>
      </div>
      <div class="card-action">
        <div class="center">
          <a class="waves-effect waves-light btn" style="background-color: #003366;" href="/users/hod/home">Go to HOD Home</a>
        </div>
      </div>
    </div>
  </div>
</div>
{{/if_eq}}

{{#if_eq user.type 'manager'}}
<h5 class="blue-text text-darken-4">WIT Appraisal Management</h5><br>
<div class="row">
  <div class="col s12 m12">
    <div class="card white darken-4" style="border-top: 5px solid #003366;">
      <div class="card-content black-text">
        <span class="card-title" style="font-weight: bold; color: #003366;">WIT Management Portal</span>
        <p>This section is for institute-level administration and Annual Confidential Report (ACR) management.</p>
      </div>
      <div class="card-action">
        <div class="center">
          <a class="waves-effect waves-light btn" style="background-color: #003366;" href="/users/management/home">Admin Dashboard</a>
        </div>
      </div>
    </div>
  </div>
</div>
{{/if_eq}}

{{#unless user}}
<h5 class="center-align" style="color: #003366;">WIT PBAS Assessment Portal</h5><br>
<div class="row">
  <div class="col s12 m8 offset-m2">
    <div class="card white center-align" style="border-top: 5px solid #003366; padding: 20px;">
      <div class="center-align" style="margin-bottom: 20px;">
         <img src="/images/logo.png" alt="WIT Logo" style="height: 60px; display: inline-block;">
      </div>
      <div class="card-content black-text">
        <span class="card-title" style="font-weight: bold; color: #003366;">Walchand Institute of Technology, Solapur</span>
        <p>(An Autonomous Institute affiliated to P.A. H. Solapur University, Solapur)</p>
        <p style="margin-top: 15px;">Welcome to the Annual Self-Assessment portal for the PBAS. Please login below.</p>
      </div>
      <div class="card-action">
        <div class="row">
          <div class="col s12 m4" style="margin-bottom:10px;">
            <a class="waves-effect waves-light btn" style="background-color: #003366; width: 100%;" href="/users/faculty/login">Faculty Login</a>
          </div>
          <div class="col s12 m4" style="margin-bottom:10px;">
            <a class="waves-effect waves-light btn" style="background-color: #003366; width: 100%;" href="/users/hod/login">HOD Login</a>
          </div>
          <div class="col s12 m4" style="margin-bottom:10px;">
            <a class="waves-effect waves-light btn" style="background-color: #cc3333; width: 100%;" href="/users/management/login">Admin Login</a>
          </div>
        </div>
        
        <div class="row" style="margin-top: 20px;">
          <div class="col s12 center-align">
            <p>New to the portal? <a href="/users/register" class="blue-text text-darken-4" style="font-weight: bold; text-decoration: underline;">Create Faculty or HOD Account</a></p>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
{{/unless}}